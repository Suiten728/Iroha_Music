# いろは Music System — 環境変数設定
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env

# ─── 必須設定 ─────────────────────────────────────────
# Discord Bot トークン（Discord Developer Portal で取得）
DISCORD_TOKEN=your_discord_bot_token_here

# ─── オプション設定 ──────────────────────────────────
# コマンドプレフィックス（デフォルト: !）
BOT_PREFIX=!

# FFmpeg パス（PATHが通っていれば "ffmpeg" のままでOK）
FFMPEG_PATH=ffmpeg

# キュー最大曲数
MAX_QUEUE_SIZE=200

# デフォルト音量 (0.0 〜 1.5)
DEFAULT_VOLUME=0.8

# 無人時の自動退出秒数
AUTO_LEAVE_SEC=300

# YouTube Data API v3 キー（任意・将来の拡張用）
# YOUTUBE_API_KEY=your_youtube_api_key_here
